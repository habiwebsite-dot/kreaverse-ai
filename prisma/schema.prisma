generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum GenerationType {
  IMAGE
  AUDIO
  VIDEO
  MASTERING
}

enum ApiKeyMode {
  SERVER_UNLIMITED
  USER_KEY
}

enum NotificationType {
  INFO
  WARNING
  DEVICE_LOCK
  TASK_UPDATE
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  name           String?
  bio            String?
  address        String?
  avatarUrl      String?
  role           Role            @default(USER)
  active         Boolean         @default(true)
  locale         String          @default("id")
  apiKeys        UserApiKey[]
  sessions       DeviceSession[]
  generations    Generation[]
  notifications  Notification[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model DeviceSession {
  id                 String         @id @default(cuid())
  userId             String
  fingerprint        String
  deviceName         String?
  userAgent          String?
  ipAddress          String?
  isActive           Boolean        @default(true)
  replaceRequestedAt DateTime?
  replacedById       String?
  lastSeenAt         DateTime       @default(now())
  createdAt          DateTime       @default(now())
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications      Notification[]

  @@unique([userId, fingerprint])
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  sessionId   String?
  type        NotificationType @default(INFO)
  title       String
  message     String
  readAt      DateTime?
  createdAt   DateTime         @default(now())
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  session     DeviceSession?   @relation(fields: [sessionId], references: [id], onDelete: SetNull)
}

model UserApiKey {
  id              String   @id @default(cuid())
  userId          String
  provider        String
  encryptedKey    String
  creditsSnapshot Float?
  lastCheckedAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model ApiKeyPool {
  id            String   @id @default(cuid())
  label         String
  provider      String   @default("evolink")
  encryptedKey  String
  priority      Int      @default(0)
  active        Boolean  @default(true)
  failureCount  Int      @default(0)
  lastFailureAt DateTime?
  lastUsedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AppSetting {
  id                 String     @id @default("singleton")
  apiKeyMode         ApiKeyMode @default(SERVER_UNLIMITED)
  whatsappTemplate   String     @default("Halo Admin Kreaverse AI, saya tertarik berlangganan. Mohon dibuatkan akun (email + password) untuk akses login ke website. Terima kasih.")
  promoBannerJson    Json?
  siteConfigJson     Json?
  updatedAt          DateTime   @updatedAt
  createdAt          DateTime   @default(now())
}

model Generation {
  id             String         @id @default(cuid())
  userId         String?
  taskId         String?        @unique
  provider       String
  model          String
  type           GenerationType
  status         String
  requestJson    Json?
  responseJson   Json?
  resultUrls     String[]
  previewUrl     String?
  errorMessage   String?
  deviceSession  String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
}