{
  "version": 2,
  "builds": [
    {
      "src": "src/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "src/index.js" },
    { "src": "/(.*\\.(png|jpg|jpeg|webp|gif|svg|ico|css|js|mp3|mp4|woff2))", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "src/index.js" }
  ]
}
