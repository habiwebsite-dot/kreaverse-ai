# Database
DATABASE_URL=postgresql://user:password@host:port/kreaverse_db

# JWT & Security
JWT_SECRET=your_jwt_secret_key_min_32_chars
JWT_EXPIRES_IN=7d

# Admin Credentials (Hashed)
ADMIN_EMAIL_HASH=sha256_hash_of_habistudio.ai@unlimited.com
ADMIN_PASSWORD_HASH=bcrypt_hash_of_habistudio.ai
ADMIN_2FA_SECRET=your_2fa_secret

# GitHub Integration
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_OWNER=habiwebsite-dot
GITHUB_REPO=kreaverse-ai

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Evolink API
EVOLINK_API_KEYS=key1,key2,key3,key4,key5
EVOLINK_BASE_URL=https://api.evolink.ai
EVOLINK_API_TIMEOUT=120000

# Auphonic
AUPHONIC_USERNAME=your_username
AUPHONIC_PASSWORD=your_password

# WhatsApp CTA
NEXT_PUBLIC_WA_NUMBER=6285119821813
NEXT_PUBLIC_WA_MESSAGE=Halo Admin Kreaverse AI, saya tertarik berlangganan. Mohon dibuatkan akun (email + password) untuk akses login ke website. Terima kasih.

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
