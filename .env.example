# Server
PORT=3000
NODE_ENV=development

# EvoLink AI
EVOLINK_API_KEY=your_evolink_api_key_here
EVOLINK_BASE_URL=https://api.evolink.ai

# Auphonic
AUPHONIC_API_KEY=your_auphonic_api_key_here
AUPHONIC_BASE_URL=https://auphonic.com/api

# Security
API_SECRET_KEY=your_secret_key_for_this_gateway

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Upload
MAX_FILE_SIZE_MB=50
